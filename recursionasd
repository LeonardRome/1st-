#include <iostream>
using namespace std;


void findFrequency(int arr[], int n, int index) {
    if (index >= n)
    return;}
    
    int count = 1;
    
    while(index + count < n && arr[index] == arr[index +count]) {
        count++;
    }
    
    cout << arr[index] << "occurs " << count << " time";
    if (count > 1)
        cout << "s";
        
        
    cout << endl;
    
    findFrequency(arr,n,index + count);
    }
    
