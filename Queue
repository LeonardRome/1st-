#include <iostream>
using namespace std;
// queue adds value at the end pos
const int SIZE = 5;

int queueArr[SIZE];
int front = 0, rear = 0;

void enqueue(int value) {
    if (rear == SIZE) {
        cout << "Queue is full!\n";
        return;
    }
    
    queueArr[rear] = value;
    rear++;
    
    cout << value << " inserted\n";
}

void dequeue(){
    if (front == rear) { //this is how we check if the queue is empty
        cout << "Queue is empty!\n";
    }
    
    cout << queueArr[front] << " removed\n";
    front++;
}

void display (){
    if (front == rear) {
        cout << "Queue is empty\n";
        return;
    }
    
    cout << "Queue: ";
    for (int i = front; i < rear; i++) {
        cout << queueArr[i] << " ";
    }
    cout << endl;
}

int main(){
    enqueue(10);
    enqueue(20);
    enqueue(30);
    
    display();
    
    dequeue();
    display();
    
    return 0;
    
}
